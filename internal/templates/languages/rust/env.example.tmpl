{{- $rust := .ADL.Spec.Language.Rust -}}
# Local environment for {{ .ADL.Metadata.Name }}
# Copy to .env and adjust values as needed.

# Server
PORT={{ .ADL.Spec.Server.Port | default 8080 }}
DEBUG={{ .ADL.Spec.Server.Debug }}
RUST_LOG=info
{{- if .ADL.Spec.Agent }}

# Agent / LLM client
# Defaults point at the docker-compose `gateway` service name. Override with
# http://localhost:<port>/v1 if you're running the Inference Gateway directly
# on the host on a port other than this agent's PORT.
AGENT_CLIENT_PROVIDER={{ .ADL.Spec.Agent.Provider }}
AGENT_CLIENT_MODEL={{ .ADL.Spec.Agent.Model }}
AGENT_CLIENT_BASE_URL=http://gateway:8080/v1
INFERENCE_GATEWAY_URL=http://gateway:8080/v1
# AGENT_CLIENT_API_KEY=
{{- if .ADL.Spec.Agent.MaxTokens }}
AGENT_CLIENT_MAX_TOKENS={{ .ADL.Spec.Agent.MaxTokens }}
{{- end }}
{{- if .ADL.Spec.Agent.Temperature }}
AGENT_CLIENT_TEMPERATURE={{ .ADL.Spec.Agent.Temperature }}
{{- end }}
{{- end }}
{{- if has "redis" $rust.Features }}

# Task queue (Redis-backed via the `redis` Cargo feature)
A2A_QUEUE_PROVIDER=redis
A2A_QUEUE_URL=redis://localhost:6379
A2A_QUEUE_NAMESPACE=a2a
{{- end }}
