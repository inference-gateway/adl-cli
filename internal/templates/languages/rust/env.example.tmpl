{{- $rust := .ADL.Spec.Language.Rust -}}
# Local environment for {{ .ADL.Metadata.Name }}
# Copy to .env and adjust values as needed. dotenvy loads this file at startup.

# Server
A2A_SERVER_PORT={{ .ADL.Spec.Server.Port | default 8080 }}
A2A_DEBUG={{ .ADL.Spec.Server.Debug }}
RUST_LOG=info
{{- if .ADL.Spec.Agent }}

# Agent / LLM client
# Default base URL targets the docker-compose `gateway` service name.
# Override with http://localhost:<port>/v1 when running the Inference
# Gateway directly on the host on a port other than this agent's port.
A2A_AGENT_CLIENT_PROVIDER={{ .ADL.Spec.Agent.Provider }}
A2A_AGENT_CLIENT_MODEL={{ .ADL.Spec.Agent.Model }}
A2A_AGENT_CLIENT_BASE_URL=http://gateway:8080/v1
# A2A_AGENT_CLIENT_API_KEY=
{{- if .ADL.Spec.Agent.MaxTokens }}
A2A_AGENT_CLIENT_MAX_TOKENS={{ .ADL.Spec.Agent.MaxTokens }}
{{- end }}
{{- if .ADL.Spec.Agent.Temperature }}
A2A_AGENT_CLIENT_TEMPERATURE={{ .ADL.Spec.Agent.Temperature }}
{{- end }}
{{- end }}
{{- if has "redis" $rust.Features }}

# Task queue (Redis-backed via the `redis` Cargo feature)
A2A_QUEUE_PROVIDER=redis
A2A_QUEUE_URL=redis://localhost:6379
A2A_QUEUE_NAMESPACE=a2a
{{- end }}
{{- $hasFetch := false }}
{{- range .ADL.Spec.Tools }}
{{- if eq .ID "fetch" }}
{{- $hasFetch = true }}
{{- end }}
{{- end }}
{{- if $hasFetch }}

# Fetch built-in tool (overrides for spec.config.tools.fetch)
# A2A_FETCH_DISABLED=1                       # runtime kill switch
# A2A_FETCH_ALLOWED_DOMAINS=example.com,.api.dev
# A2A_FETCH_MAX_BYTES=10485760               # 10 MiB
# A2A_FETCH_TIMEOUT_SECONDS=30
# A2A_FETCH_DOWNLOAD_DIR=/tmp
# A2A_FETCH_ALLOW_DOWNLOADS=false
{{- end }}
