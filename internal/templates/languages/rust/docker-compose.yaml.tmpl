{{- $rust := .ADL.Spec.Language.Rust -}}
services:
  {{ .ADL.Metadata.Name }}:
    build: .
    ports:
      - "{{ .ADL.Spec.Server.Port | default 8080 }}:{{ .ADL.Spec.Server.Port | default 8080 }}"
    environment:
      A2A_SERVER_PORT: "{{ .ADL.Spec.Server.Port | default 8080 }}"
      {{- if .ADL.Spec.Agent }}
      A2A_AGENT_CLIENT_PROVIDER: "{{ .ADL.Spec.Agent.Provider }}"
      A2A_AGENT_CLIENT_MODEL: "{{ .ADL.Spec.Agent.Model }}"
      A2A_AGENT_CLIENT_BASE_URL: "${A2A_AGENT_CLIENT_BASE_URL:-http://gateway:8080/v1}"
      {{- end }}
      {{- if has "redis" $rust.Features }}
      A2A_QUEUE_PROVIDER: redis
      A2A_QUEUE_URL: "redis://redis:6379"
      A2A_QUEUE_NAMESPACE: a2a
      {{- end }}
    {{- if has "redis" $rust.Features }}
    depends_on:
      redis:
        condition: service_healthy

  redis:
    image: redis:8-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    volumes:
      - redis-data:/data

volumes:
  redis-data:
    {{- end }}
