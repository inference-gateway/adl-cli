use inference_gateway_adk::{A2AServerBuilder, {{ if .ADL.Spec.Agent }}AgentBuilder, {{ end }}Config};
{{- if .ADL.Spec.Agent }}
use inference_gateway_sdk::{ChatCompletionTool, ChatCompletionToolType, FunctionObject, FunctionParameters};
use serde_json::{Value, json};
{{- end }}
use std::env;
use std::net::SocketAddr;
use tracing::{error, info};

{{- if .ADL.Spec.Skills }}

mod skills;
{{- end }}

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    tracing_subscriber::fmt()
        .with_env_filter(
            tracing_subscriber::EnvFilter::try_from_default_env()
                .unwrap_or_else(|_| tracing_subscriber::EnvFilter::new("info,tower_http=debug")),
        )
        .init();

    let mut config = Config::from_env()?;
{{- if .ADL.Spec.Agent }}

    let gateway_url = env::var("INFERENCE_GATEWAY_URL")
        .unwrap_or_else(|_| "http://localhost:8080/v1".to_string());
    if config.agent_config.base_url.is_none() {
        config.agent_config.base_url = Some(gateway_url.clone());
    }
    if config.agent_config.provider.is_empty() {
        config.agent_config.provider = {{ .ADL.Spec.Agent.Provider | quote }}.to_string();
    }
    if config.agent_config.model.is_empty() {
        config.agent_config.model = {{ .ADL.Spec.Agent.Model | quote }}.to_string();
    }
    {{- if .ADL.Spec.Agent.MaxTokens }}
    if config.agent_config.max_tokens == 0 {
        config.agent_config.max_tokens = {{ .ADL.Spec.Agent.MaxTokens }};
    }
    {{- end }}

    info!(
        provider = %config.agent_config.provider,
        model = %config.agent_config.model,
        "starting {{ .ADL.Metadata.Name }} agent",
    );

    let tools: Vec<ChatCompletionTool> = vec![
{{- range .ADL.Spec.Skills }}
        ChatCompletionTool {
            type_: ChatCompletionToolType::Function,
            function: FunctionObject {
                name: {{ .ID | quote }}.to_string(),
                description: Some({{ .Description | quote }}.to_string()),
                parameters: Some(FunctionParameters(
                    json!({{ toJson .Schema }})
                        .as_object()
                        .expect("skill schema must be a JSON object")
                        .clone(),
                )),
                strict: false,
            },
        },
{{- end }}
    ];

    let agent = AgentBuilder::new()
        .with_config(&config.agent_config)
        .with_system_prompt({{ .ADL.Spec.Agent.SystemPrompt | quote }})
        .with_toolbox(tools)
{{- range .ADL.Spec.Skills }}
{{- if .Inject }}
        .with_async_function_tool({{ .ID | quote }}.to_string(), |args: Value| async move {
            skills::{{ toSnakeCase .ID }}::handle(args).await
        })
{{- else }}
        .with_function_tool({{ .ID | quote }}.to_string(), |args: Value| {
            skills::{{ toSnakeCase .ID }}::handle(args)
        })
{{- end }}
{{- end }}
        .build()
        .await?;
{{- else }}

    info!("starting {{ .ADL.Metadata.Name }} agent");
{{- end }}

    let server = A2AServerBuilder::new()
        .with_config(config)
{{- if .ADL.Spec.Agent }}
        .with_agent(agent)
        .with_gateway_url(gateway_url)
{{- end }}
        .with_agent_card_from_file(".well-known/agent-card.json", None)
        .with_default_task_handlers()
        .build()
        .await?;

    let port: u16 = env::var("PORT")
        .ok()
        .and_then(|s| s.parse().ok())
        .unwrap_or({{ .ADL.Spec.Server.Port | default 8080 }});
    let addr: SocketAddr = format!("0.0.0.0:{}", port).parse()?;
    info!("A2A server listening on {addr}");

    if let Err(e) = server.serve(addr).await {
        error!("server stopped: {e}");
    }

    Ok(())
}
