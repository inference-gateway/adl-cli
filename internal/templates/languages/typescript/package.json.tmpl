{
  "name": {{ .ADL.Spec.Language.TypeScript.PackageName | toJson }},
  "version": {{ .ADL.Metadata.Version | toJson }},
  "description": {{ .ADL.Metadata.Description | toJson }},
  "type": "module",
  "private": true,
  "engines": {
    "node": ">={{ .ADL.Spec.Language.TypeScript.NodeVersion }}"
  },
  "main": "dist/index.js",
  "scripts": {
    "validate": "adl validate agent.yaml",
    "generate": {{ .GenerateCommand | toJson }},
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "node --test",
    "test:coverage": "node --test --experimental-test-coverage"
  },
  "dependencies": {
    "@inference-gateway/adk": "0.11.0"{{- range .Vendor.NpmDeps }},
    {{ .Name | toJson }}: {{ .Version | toJson }}{{- end }}
  },
  "devDependencies": {
    {{- if and .Metadata.CLIVersion (ne .Metadata.CLIVersion "dev") }}
    "@inference-gateway/adl-cli": {{ .Metadata.CLIVersion | toJson }},
    {{- else }}
    "@inference-gateway/adl-cli": "latest",
    {{- end }}
    "@types/node": "^24.1.0",
    "prettier": "^3.8.3",
    "tsx": "^4.19.2",
    "typescript": "^6.0.3"{{- range .Vendor.NpmDevDeps }},
    {{ .Name | toJson }}: {{ .Version | toJson }}{{- end }}
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@inference-gateway/adl-cli",
      "esbuild",
      "protobufjs"
    ]
  }
}
