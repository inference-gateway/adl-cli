# pnpm 11.5+ reads settings from this file, not the `pnpm` field in package.json.
# Pre-approve dependencies that run install/build scripts; without this pnpm
# skips them and the native `adl` binary (adl-cli postinstall) is never fetched.
allowBuilds:
  '@inference-gateway/adl-cli': false
  esbuild: false
  protobufjs: false
minimumReleaseAgeExclude:
  {{- if and .Metadata.CLIVersion (ne .Metadata.CLIVersion "dev") }}
  - '@inference-gateway/adl-cli@{{ .Metadata.CLIVersion }}'
  {{- end }}
