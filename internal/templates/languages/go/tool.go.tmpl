					{{- else if eq $k "properties" }}
					"{{ $k }}": {{ $v | toGoMap }},
					{{- else if eq $k "items" }}
					"{{ $k }}": {{ $v | toGoMap }},
					{{- else }}
					"{{ $k }}": {{ $v | toJson }},
					{{- end }}
					{{- end }}
				},
				{{- end }}
			},
			{{- if .Schema.required }}
			"required": []string{ {{- range $i, $field := .Schema.required }}{{ if $i }}, {{ end }}"{{ $field }}"{{ end -}} },
			{{- end }}
		},
		tool.{{ .Name | toPascalCase }}Handler,
	)
}

