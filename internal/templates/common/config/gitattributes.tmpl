# Generated files by ADL CLI
# These files are automatically generated and should not be manually edited

{{- if eq .Language "go" }}
# Core Go generated files
main.go linguist-generated=true
go.mod linguist-generated=true
go.sum linguist-generated=true
{{- else if eq .Language "rust" }}
# Core Rust generated files
src/main.rs linguist-generated=true
Cargo.toml linguist-generated=true
Cargo.lock linguist-generated=true
{{- else if eq .Language "typescript" }}
# Core TypeScript generated files
src/index.ts linguist-generated=true
package.json linguist-generated=true
package-lock.json linguist-generated=true
tsconfig.json linguist-generated=true
{{- end }}

# Build and deployment files
Dockerfile linguist-generated=true
.dockerignore linguist-generated=true
Taskfile.yml linguist-generated=true
.gitignore linguist-generated=true

{{- if and .ADL.Spec.Development .ADL.Spec.Development.Sandbox .ADL.Spec.Development.Sandbox.DockerCompose .ADL.Spec.Development.Sandbox.DockerCompose.Enabled }}

# Docker Compose dev stack (generated)
docker-compose.yaml linguist-generated=true
.env.example linguist-generated=true
{{- end }}

# CI/CD workflows
.github/workflows/ci.yml linguist-generated=true
.github/workflows/cd.yml linguist-generated=true
.releaserc.yaml linguist-generated=true

{{- $scmProvider := "" }}
{{- if .ADL.Spec.SCM }}{{- $scmProvider = printf "%s" .ADL.Spec.SCM.Provider }}{{- end }}
{{- if and .ADL.Spec.SCM .ADL.Spec.SCM.Dependabot (or (eq $scmProvider "github") (eq $scmProvider "")) }}

# Dependabot configuration
.github/dependabot.yml linguist-generated=true
{{- end }}

{{- if .AIToggles.ClaudeCode }}

# AI assistant documentation (generated)
CLAUDE.md linguist-generated=true
{{- end }}
{{- if .AIToggles.Gemini }}
{{- if not .AIToggles.ClaudeCode }}

# AI assistant documentation (generated)
{{- end }}
GEMINI.md linguist-generated=true
{{- end }}
{{- if .AIToggles.AnyAgentsMD }}
{{- if not (or .AIToggles.ClaudeCode .AIToggles.Gemini) }}

# AI assistant documentation (generated)
{{- end }}
AGENTS.md linguist-generated=true
{{- end }}
{{- if .AIToggles.ClaudeCode }}
.github/workflows/claude.yml linguist-generated=true
{{- end }}
{{- if .AIToggles.Codex }}
.github/workflows/codex.yml linguist-generated=true
{{- end }}
{{- if .AIToggles.Gemini }}
.github/workflows/gemini.yml linguist-generated=true
{{- end }}

# Kubernetes manifests
k8s/*.yaml linguist-generated=true
k8s/*.yml linguist-generated=true

# Agent capabilities
.well-known/agent-card.json linguist-generated=true

{{- $hasBuiltinTools := false }}
{{- range .ADL.Spec.Tools }}
  {{- if isBuiltinToolID .ID }}
    {{- $hasBuiltinTools = true }}
  {{- end }}
{{- end }}
{{- if $hasBuiltinTools }}

# Built-in tools (generated from ADL CLI templates)
{{- range .ADL.Spec.Tools }}
  {{- if isBuiltinToolID .ID }}
    {{- if eq $.Language "go" }}
tools/{{ .ID }}.go linguist-generated=true
    {{- else if eq $.Language "rust" }}
src/tools/{{ .ID }}.rs linguist-generated=true
    {{- else if eq $.Language "typescript" }}
src/tools/{{ .ID }}.ts linguist-generated=true
    {{- end }}
  {{- end }}
{{- end }}
{{- end }}

# Documentation (partially generated)
README.md linguist-documentation=true

# Preserve line endings for generated files
{{- if eq .Language "go" }}
*.go text eol=lf
{{- else if eq .Language "rust" }}
*.rs text eol=lf
*.toml text eol=lf
{{- else if eq .Language "typescript" }}
*.ts text eol=lf
*.js text eol=lf
*.tsx text eol=lf
*.jsx text eol=lf
{{- end }}
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
Taskfile.yml text eol=lf
