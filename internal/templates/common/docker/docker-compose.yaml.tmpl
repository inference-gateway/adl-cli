{{- $port := .ADL.Spec.Server.Port | default 8080 -}}
{{- $name := .ADL.Metadata.Name -}}
{{- $hasRedis := false -}}
{{- if .ADL.Spec.Language.Rust -}}
{{- if has "redis" .ADL.Spec.Language.Rust.Features -}}
{{- $hasRedis = true -}}
{{- end -}}
{{- end -}}
# Local development stack for {{ $name }}.
#
# Brings up the Inference Gateway, this A2A agent (built from the local
# Dockerfile so code changes are picked up), and gives you opt-in profiles
# for the `infer` CLI and the `a2a-debugger` so the agent can be exercised
# end-to-end without manual wiring.
#
#   docker compose up --build              # gateway + agent{{ if $hasRedis }} + redis{{ end }}
#   docker compose --profile cli run --rm cli         # interactive infer CLI
#   docker compose --profile debugger run --rm debugger \
#     --server-url http://{{ $name }}:{{ $port }} tasks list
#
# The `gateway` service reads provider API keys from `.env` if present
# (copy `.env.example` -> `.env` and fill in keys). Override host port
# mappings via GATEWAY_HOST_PORT / AGENT_HOST_PORT, e.g.
#   GATEWAY_HOST_PORT=8090 docker compose up

services:
  gateway:
    image: ghcr.io/inference-gateway/inference-gateway:latest
    pull_policy: always
    restart: unless-stopped
    ports:
      - "${GATEWAY_HOST_PORT:-8080}:8080"
    env_file:
      - path: .env
        required: false
    environment:
      ENVIRONMENT: development
      SERVER_HOST: 0.0.0.0
      SERVER_PORT: "8080"
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://localhost:8080/health"]
      interval: 10s
      timeout: 3s
      retries: 5
      start_period: 5s

  {{ $name }}:
    build: .
    restart: unless-stopped
    ports:
      - "${AGENT_HOST_PORT:-{{ $port }}}:{{ $port }}"
    environment:
      A2A_SERVER_PORT: "{{ $port }}"
      {{- if .ADL.Spec.Agent }}
      A2A_AGENT_CLIENT_PROVIDER: "{{ .ADL.Spec.Agent.Provider }}"
      A2A_AGENT_CLIENT_MODEL: "{{ .ADL.Spec.Agent.Model }}"
      A2A_AGENT_CLIENT_BASE_URL: "${A2A_AGENT_CLIENT_BASE_URL:-http://gateway:8080/v1}"
      {{- end }}
      {{- if $hasRedis }}
      A2A_QUEUE_PROVIDER: redis
      A2A_QUEUE_URL: "redis://redis:6379"
      A2A_QUEUE_NAMESPACE: a2a
      {{- end }}
    depends_on:
      gateway:
        condition: service_healthy
      {{- if $hasRedis }}
      redis:
        condition: service_healthy
      {{- end }}

  # Inference Gateway CLI - opt-in via `--profile cli`.
  # Talks to the gateway over the compose network as `gateway:8080`.
  cli:
    image: ghcr.io/inference-gateway/cli:latest
    profiles: ["cli"]
    pull_policy: always
    stdin_open: true
    tty: true
    env_file:
      - path: .env
        required: false
    environment:
      GATEWAY_URL: "http://gateway:8080"
    depends_on:
      gateway:
        condition: service_healthy

  # A2A Debugger - opt-in via `--profile debugger`.
  # Example:
  #   docker compose --profile debugger run --rm debugger \
  #     --server-url http://{{ $name }}:{{ $port }} tasks submit "What are your skills?"
  debugger:
    image: ghcr.io/inference-gateway/a2a-debugger:latest
    profiles: ["debugger"]
    pull_policy: always
    stdin_open: true
    tty: true
    depends_on:
      {{ $name }}:
        condition: service_started
{{- if $hasRedis }}

  redis:
    image: redis:8-alpine
    ports:
      - "6379:6379"
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 5s
      timeout: 3s
      retries: 5
    volumes:
      - redis-data:/data

volumes:
  redis-data:
{{- end }}
